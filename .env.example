# Vector store engine selection (Phase 15 D-01, D-02)
# Start with Weaviate (default): docker compose --profile weaviate up
# Start with Qdrant:             docker compose --profile qdrant up
VECTOR_STORE_ENGINE=weaviate

# Vector store URL — used by orchestrator to connect to the selected engine
VECTOR_STORE_URL=http://vector-db:8080   # Weaviate (default)
# VECTOR_STORE_URL=http://vector-db-qdrant:6333  # Qdrant

# Legacy Weaviate URL (backward compat — overridden by VECTOR_STORE_URL if set)
WEAVIATE_URL=http://vector-db:8080

# Optional: external embedding provider API keys
# Leave blank for POC default (weaviate_builtin / text2vec-transformers)
OPENAI_API_KEY=
COHERE_API_KEY=
VOYAGE_API_KEY=

# Optional: relational DB credentials (used by Phase 2+ DB adapters)
DB_USER=
DB_PASSWORD=
DB_HOST=
DB_PORT=
DB_NAME=

# Optional: MongoDB
MONGODB_URI=

# Authentication (Phase 12)
# Generate JWT_SECRET with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=<genera con: python -c "import secrets; print(secrets.token_hex(32))">
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme
