# Vector store engine + Docker Compose profile (Phase 15 D-01, D-02)
# COMPOSE_PROFILES is read automatically by Docker Compose from this file —
# no need to pass --profile on the command line when it's set here.
#
# Per usare Qdrant (default consigliato):
VECTOR_STORE_ENGINE=qdrant
COMPOSE_PROFILES=qdrant
VECTOR_STORE_URL=http://vector-db-qdrant:6333
#
# Per usare Weaviate, sostituire le tre righe sopra con:
# VECTOR_STORE_ENGINE=weaviate
# COMPOSE_PROFILES=weaviate
# VECTOR_STORE_URL=http://vector-db:8080

# Legacy Weaviate URL (backward compat — overridden by VECTOR_STORE_URL if set)
WEAVIATE_URL=http://vector-db:8080

# Optional: external embedding provider API keys
OPENAI_API_KEY=
COHERE_API_KEY=
VOYAGE_API_KEY=

# Optional: relational DB credentials (used by Phase 2+ DB adapters)
MYSQL_HOST=
MYSQL_DB=
MYSQL_USER=
MYSQL_PASSWORD=

# Optional: MongoDB
MONGODB_URI=

# Authentication (Phase 12)
# Generate JWT_SECRET with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=<genera con: python -c "import secrets; print(secrets.token_hex(32))">
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme
